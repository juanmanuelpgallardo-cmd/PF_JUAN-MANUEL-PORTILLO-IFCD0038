---
// Componente Hero cyber-street food - The Walkers
---

<section id="inicio" class="hero">
  {/* Video de fondo */}
  <div class="hero-video-wrapper">
    <video 
      class="hero-video" 
      autoplay 
      muted 
      loop 
      playsinline
      poster="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=1920&h=1080&fit=crop"
    >
      <source src="https://videos.pexels.com/video-files/3129954/3129954-uhd_2560_1440_30fps.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
  </div>

  {/* Contenido */}
  <div class="hero-content">
    <div class="container">
      <div class="hero-inner">
        <p class="hero-badge">🔥 THE WALKERS</p>
        <h1 class="hero-title">
          SABOR <span class="hero-neon">CALLEJERO</span><br />
          TÉCNICA DE <span class="hero-cyan">AUTOR</span>
        </h1>
        <p class="hero-subtitle">
          Rolls fusión · Tacos asiáticos · Burgers gourmet · Bowls
        </p>
        <div class="hero-buttons">
          <a href="#pedir" class="btn btn-primary btn-hero">¡PIDE YA!</a>
          <a href="#carta" class="btn btn-outline btn-hero-outline">VER CARTA</a>
        </div>
      </div>
    </div>
  </div>

  {/* Indicador de scroll */}
  <div class="scroll-indicator">
    <span class="mouse"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--color-white);
    padding: 0;
  }

  .hero-video-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(13, 13, 17, 0.85) 0%,
      rgba(13, 13, 17, 0.6) 50%,
      rgba(13, 13, 17, 0.9) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }

  .hero-inner {
    max-width: 850px;
    text-align: center;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--spacing-lg);
    border: 1px solid rgba(255, 94, 54, 0.3);
    padding: 0.5rem 1.5rem;
    backdrop-filter: blur(4px);
  }

  .hero-title {
    font-size: 5rem;
    margin-bottom: var(--spacing-lg);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-white);
    text-transform: uppercase;
  }

  .hero-neon {
    color: var(--color-accent);
    text-shadow: 0 0 30px rgba(255, 94, 54, 0.4);
  }

  .hero-cyan {
    color: var(--color-neon-cyan);
    text-shadow: 0 0 30px rgba(0, 229, 255, 0.4);
  }

  .hero-subtitle {
    font-size: 1.3rem;
    margin-bottom: var(--spacing-xl);
    line-height: 1.7;
    font-weight: 400;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-buttons {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-hero {
    padding: 1rem 2.5rem;
    font-size: 1.2rem;
  }

  .btn-hero-outline {
    padding: 1rem 2.5rem;
    font-size: 1.2rem;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    animation: bounce 2s infinite;
  }

  .mouse {
    display: block;
    width: 24px;
    height: 40px;
    border: 2px solid rgba(0, 229, 255, 0.4);
    border-radius: 12px;
    position: relative;
    margin: 0 auto;
  }

  .mouse::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    width: 2px;
    height: 6px;
    background-color: rgba(0, 229, 255, 0.5);
    border-radius: 2px;
    transform: translateX(-50%);
    animation: scroll 2s infinite;
  }

  @keyframes scroll {
    0% {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateX(-50%) translateY(12px);
    }
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(-8px);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
    }

    .hero-title {
      font-size: 2.8rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn-hero,
    .btn-hero-outline {
      width: 100%;
      max-width: 320px;
    }

    .scroll-indicator {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }

    .hero-badge {
      font-size: 0.7rem;
      padding: 0.4rem 1rem;
    }
  }
</style>
