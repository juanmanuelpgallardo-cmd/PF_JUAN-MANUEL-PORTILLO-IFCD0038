---
// Componente Reviews cyber - The Walkers

const reviews = [
  {
    name: "MARÍA GARCÍA",
    role: "BLOGUERA GASTRONÓMICA",
    content: "Los rolls fusión son una locura. El contraste de texturas y sabores me voló la cabeza. Y el ambiente oscuro con luces neón es perfecto para cenas informales pero con estilo.",
    rating: 5,
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop"
  },
  {
    name: "CARLOS LÓPEZ",
    role: "DIRECTOR EMPRESARIAL",
    content: "Pedí para llevar a la oficina y todos fliparon. La burger wasabi-mango es adictiva. Comida rápida de verdad, pero con una calidad que no esperas de un takeaway.",
    rating: 5,
    avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop"
  },
  {
    name: "LAURA MARTÍNEZ",
    role: "FOOD PHOTOGRAPHER",
    content: "Los tacos asiáticos son fotogénicos y deliciosos. Me encanta que usen ingredientes frescos y se note. Por fin un sitio que entiende el street food de verdad.",
    rating: 5,
    avatar: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop"
  },
  {
    name: "MIGUEL RODRÍGUEZ",
    role: "CHEF DE COCINA FUSIÓN",
    content: "Como cocinero, valoro cuando un sitio hace bien la fusión. The Walkers lo clava: respeta las bases pero se atreve a innovar. El poke bowl es de lo mejor que he probado.",
    rating: 5,
    avatar: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop"
  }
];
---

<section id="testimonios" class="reviews">
  <div class="container">
    <div class="section-header">
      <p class="section-badge">RESEÑAS</p>
      <h2>LO QUE DICEN</h2>
      <p>Opiniones reales de quienes ya han probado nuestra fusión urbana</p>
    </div>

    <div class="reviews-grid">
      {reviews.map((review) => (
        <div class="review-card">
          <div class="review-header">
            <img 
              src={review.avatar} 
              alt={review.name}
              class="review-avatar"
              loading="lazy"
            />
            <div class="review-info">
              <h4 class="review-name">{review.name}</h4>
              <p class="review-role">{review.role}</p>
            </div>
          </div>

          <div class="review-stars">
            {[...Array(review.rating)].map(() => (
              <span class="star">★</span>
            ))}
          </div>

          <p class="review-content">
            "{review.content}"
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    background-color: var(--color-surface);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--spacing-sm);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 2.8rem;
  }

  .section-header p {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 550px;
    margin: 0 auto;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .review-card {
    background-color: var(--color-primary);
    padding: var(--spacing-lg);
    border-left: 4px solid var(--color-accent);
    transition: all var(--transition-normal);
    border: 1px solid rgba(255, 94, 54, 0.1);
  }

  .review-card:hover {
    box-shadow: 0 0 20px rgba(255, 94, 54, 0.1);
    transform: translateY(-4px);
    border-left-color: var(--color-neon-cyan);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .review-avatar {
    width: 48px;
    height: 48px;
    object-fit: cover;
    filter: grayscale(30%);
  }

  .review-info {
    flex: 1;
  }

  .review-name {
    font-size: 1rem;
    margin-bottom: 2px;
    color: var(--color-white);
    font-family: var(--font-display);
    letter-spacing: 0.06em;
  }

  .review-role {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin: 0;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .review-stars {
    display: flex;
    gap: 4px;
    margin-bottom: var(--spacing-md);
  }

  .star {
    color: var(--color-accent);
    font-size: 1.2rem;
  }

  .review-content {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 2rem;
    }

    .reviews-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .review-card {
      padding: var(--spacing-md);
    }
  }
</style>
