---
// Componente Header oscuro cyber-gourmet - The Walkers
---

<header class="header" id="top">
  <div class="container header-content">
    {/* Logo */}
    <div class="logo">
      <a href="#inicio" class="logo-link">
        <span class="logo-text">THE WALKERS</span>
      </a>
    </div>

    {/* Navegación */}
    <nav class="nav" aria-label="Navegación principal">
      <ul class="nav-list">
        <li><a href="#inicio" class="nav-link">INICIO</a></li>
        <li><a href="#esencia" class="nav-link">ESENCIA</a></li>
        <li><a href="#carta" class="nav-link">CARTA</a></li>
        <li><a href="#testimonios" class="nav-link">RESEÑAS</a></li>
        <li><a href="#contacto" class="nav-link">CONTACTO</a></li>
      </ul>
    </nav>

    {/* CTA Button */}
    <div class="header-cta">
      <a href="#pedir" class="btn btn-primary">¡PIDE YA!</a>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: rgba(13, 13, 17, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: all var(--transition-normal);
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) 0;
  }

  .logo {
    flex-shrink: 0;
  }

  .logo-link {
    text-decoration: none;
  }

  .logo-text {
    font-size: 1.6rem;
    color: var(--color-white);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .nav {
    flex: 1;
    margin: 0 var(--spacing-2xl);
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--spacing-xl);
    align-items: center;
    justify-content: center;
  }

  .nav-link {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--transition-fast);
    position: relative;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    font-family: var(--font-body);
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width var(--transition-fast);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .header-cta {
    flex-shrink: 0;
  }

  .header-cta .btn {
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .header-content {
      flex-direction: column;
      gap: var(--spacing-sm);
      padding: var(--spacing-sm) 0;
    }

    .nav {
      margin: var(--spacing-sm) 0;
      width: 100%;
    }

    .nav-list {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--spacing-sm);
    }

    .logo-text {
      font-size: 1.3rem;
    }

    .nav-link {
      font-size: 0.75rem;
    }
  }
</style>
