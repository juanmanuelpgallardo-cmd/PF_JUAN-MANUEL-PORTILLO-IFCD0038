];
---

<section id="carta" class="menu-section">
  <div class="container">
    {/* Header */}
    <div class="section-header">
      <p class="section-badge">DESCUBRE</p>
      <h2>NUESTRA CARTA</h2>
      <p class="section-subtitle">
        Platos estrella, menús degustación, experiencias en grupo y ofertas para llevar
      </p>
    </div>

    {/* Filtro Isótopo */}
    <div class="filter-tabs" id="filterTabs">
      {categorias.map((cat) => (
        <button
          class="filter-btn"
          data-filter={cat.id}
          aria-pressed={cat.id === "todo" ? "true" : "false"}
        >
          {cat.label}
        </button>
      ))}
    </div>

    {/* Grid de platos */}
    <div class="menu-grid" id="menuGrid">
      {items.map((item) => (
        <article
          class={`menu-card ${item.tipo === "degustacion" ? "menu-card--degustacion" : ""} ${item.tipo === "grupo" ? "menu-card--grupo" : ""} ${item.tipo === "takeaway" ? "menu-card--takeaway" : ""}`}
          data-categoria={item.categoria}
        >
          {/* Imagen */}
          <div class="menu-card-image">
            <img
              src={item.imagen}
              alt={item.nombre}
              loading="lazy"
            />
            {item.badge && (
              <span class="menu-badge">{item.badge}</span>
            )}
          </div>

          {/* Contenido */}
          <div class="menu-card-body">
            <h3 class="menu-card-title">{item.nombre}</h3>
            <p class="menu-card-desc">{item.descripcion}</p>

            {/* Items incluidos (Degustación / Grupos) */}
            {item.incluye && item.incluye.length > 0 && (
              <ul class="menu-card-incluye">
                {item.incluye.map((linea) => (
                  <li>{linea}</li>
                ))}
              </ul>
            )}

            {/* Precio y CTA */}
            <div class="menu-card-footer">
              {item.precio && (
                <span class="menu-card-price">{item.precio}</span>
              )}

              {item.categoria === "grupos" ? (
                <a
                  href="https://wa.me/34912345678"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-cta btn-whatsapp"
                >
                  RESERVAR PARA MI GRUPO
                </a>
              ) : item.categoria === "llevar" ? (
                <button class="btn btn-cta btn-add-cart">
                  AÑADIR AL CARRITO
                </button>
              ) : (
                <a href="#pedir" class="btn btn-cta">
                  PEDIR AHORA
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .menu-section {
    background-color: var(--color-primary);
    padding: var(--spacing-2xl) 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .section-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--spacing-sm);
  }

  .section-header h2 {
    color: var(--color-white);
    font-size: 2.8rem;
    margin-bottom: var(--spacing-sm);
  }

  .section-subtitle {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 550px;
    margin: 0 auto;
  }

  /* FILTER TABS */
  .filter-tabs {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-2xl);
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .filter-btn {
    background: transparent;
    border: none;
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    transition: all var(--transition-fast);
    position: relative;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width var(--transition-fast);
  }

  .filter-btn:hover {
    color: var(--color-white);
  }

  .filter-btn[aria-pressed="true"] {
    color: var(--color-accent);
  }

  .filter-btn[aria-pressed="true"]::after {
    width: 60%;
  }

  /* MENU GRID */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-lg);
    transition: all var(--transition-normal);
  }

  .menu-card {
    background-color: var(--color-surface);
    display: flex;
    flex-direction: column;
    transition: all var(--transition-normal);
    border: 1px solid rgba(255, 94, 54, 0.1);
    opacity: 1;
    transform: scale(1);
  }

  .menu-card:hover {
    transform: translateY(-6px);
    border-color: var(--color-accent);
    box-shadow: 0 0 25px rgba(255, 94, 54, 0.12);
  }

  .menu-card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .menu-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
    filter: brightness(0.85);
  }

  .menu-card:hover .menu-card-image img {
    transform: scale(1.05);
    filter: brightness(1);
  }

  .menu-badge {
    position: absolute;
    top: var(--spacing-sm);
    left: var(--spacing-sm);
    background-color: var(--color-accent);
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.8rem;
    box-shadow: 0 0 15px rgba(255, 94, 54, 0.4);
  }

  .menu-card-body {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .menu-card-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-white);
    margin-bottom: var(--spacing-sm);
    letter-spacing: 0.04em;
  }

  .menu-card-desc {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
  }

  .menu-card-incluye {
    list-style: none;
    margin-bottom: var(--spacing-md);
    padding: var(--spacing-md);
    background-color: rgba(0, 229, 255, 0.04);
    border-left: 2px solid var(--color-neon-cyan);
  }

  .menu-card-incluye li {
    font-size: 0.8rem;
    color: var(--color-muted);
    padding: 0.3rem 0;
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }

  .menu-card-incluye li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--color-neon-cyan);
    font-weight: 700;
  }

  .menu-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: auto;
    padding-top: var(--spacing-md);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .menu-card-price {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  /* BUTTONS */
  .btn-cta {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    padding: 0.6rem 1.2rem;
    background-color: var(--color-accent);
    color: var(--color-white);
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .btn-cta:hover {
    background-color: var(--color-accent-hover);
    transform: scale(1.03);
    color: var(--color-white);
  }

  .btn-whatsapp {
    background-color: #25D366;
    box-shadow: 0 0 15px rgba(37, 211, 102, 0.3);
  }

  .btn-whatsapp:hover {
    background-color: #20BD5A;
    box-shadow: 0 0 25px rgba(37, 211, 102, 0.5);
  }

  .btn-add-cart {
    background-color: var(--color-neon-cyan);
    color: var(--color-primary);
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.3);
  }

  .btn-add-cart:hover {
    background-color: var(--color-neon-cyan-hover);
    color: var(--color-primary);
    box-shadow: 0 0 25px rgba(0, 229, 255, 0.5);
  }

  /* DEGUSTACION CARDS - más grandes */
  .menu-card--degustacion {
    grid-column: span 1;
  }

  .menu-card--degustacion .menu-card-image {
    height: 220px;
  }

  /* TAKEAWAY CARDS */
  .menu-card--takeaway .menu-card-price {
    font-size: 1.5rem;
    color: var(--color-neon-cyan);
  }

  /* ANIMACIÓN FILTER */
  .menu-card.filter-hidden {
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    border: none;
    pointer-events: none;
    transform: scale(0.9);
  }

  .menu-card.filter-hidden .menu-card-image {
    height: 0;
    margin: 0;
  }

  .menu-card.filter-hidden .menu-card-body {
    padding: 0;
    margin: 0;
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 2rem;
    }

    .filter-tabs {
      gap: 0.3rem;
      padding: var(--spacing-sm) 0;
    }

    .filter-btn {
      font-size: 0.75rem;
      padding: 0.4rem 0.8rem;
    }

    .menu-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .menu-card--degustacion {
      grid-column: span 1;
    }

    .menu-card-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-cta {
      text-align: center;
    }
  }
</style>

  <script>
  // Filtro isótopo dinámico
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.menu-card');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const filter = tab.dataset.filter;

        tabs.forEach(t => t.setAttribute('aria-pressed', 'false'));
        tab.setAttribute('aria-pressed', 'true');

        items.forEach(item => {
          const categoria = item.dataset.categoria;
          item.classList.toggle('filter-hidden', filter !== 'todo' && categoria !== filter);
        });
      });
    });
  });
</script>