  // ===== MENÚS PARA GRUPOS =====
  {
    categoria: "grupos",
    nombre: 'Menú "The Crew"',
    descripcion: "De 4 a 6 personas. Perfecto para reuniones informales con amigos donde cada uno elige su burger.",
    precio: "24,90 €/pers.",
