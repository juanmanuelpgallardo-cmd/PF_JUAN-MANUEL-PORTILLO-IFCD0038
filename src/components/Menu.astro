    descripcion: "Doble carne smash de res madurada, queso cheddar fundido, costilla de cerdo desmechada en barbacoa de Gochujang coreana, mayonesa de sésamo negro y pan brioche tostado.",
    precio: "14,90 €",
    badge: "TOP 1",
    imagen: "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=500&h=350&fit=crop",
    tipo: "best-seller"
  },
  {
    categoria: "estrella",
    nombre: "Bao-Bacoa Pulled Pork",
    descripcion: "Panes bao al vapor rellenos de cochinita pibil mexicana fusión, cebolla encurtida con lima, cilantro fresco y un toque de salsa sriracha-miel.",
    precio: "12,50 €",
    badge: "TOP 2",
    imagen: "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=500&h=350&fit=crop",
    tipo: "best-seller"
  },
  {
    categoria: "estrella",
    nombre: "Waffle-Chicken Tres Quesos",
    descripcion: "Pollo frito al estilo sureño ultra crujiente, servido sobre un waffle belga de queso, bañado en miel de maple picante y trozos de bacon caramelizado.",
    precio: "13,90 €",
    badge: "TOP 3",
    imagen: "https://images.unsplash.com/photo-1567620832903-9fc6debc209f?w=500&h=350&fit=crop",
    tipo: "best-seller"
  },
  {
    categoria: "estrella",
    nombre: 'Sushi Burrito "Tulum-Tokyo"',
    descripcion: "Alga nori y arroz de sushi rellenos de tartar de salmón, aguacate, queso crema, totopos crujientes y salsa chipotle-teriyaki.",
    precio: "15,50 €",
    badge: "TOP 4",
    imagen: "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=500&h=350&fit=crop",
    tipo: "best-seller"
  },

  // ===== MENÚS DEGUSTACIÓN =====
  {
    categoria: "degustacion",
    nombre: 'Menú "Street Fusion Tour"',
    descripcion: "La experiencia completa para 1 persona. Un viaje de sabores callejeros con técnica de autor.",
    precio: "29,90 €/pers.",
    imagen: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=500&h=350&fit=crop",
    tipo: "degustacion",
    incluye: [
      "Patatas gajo trufadas con parmesano e hilos de chile dulce",
      "1 Sushi Burrito o 1 Burger Fusión a elegir",
      "Tequeños de Nutella con helado de vainilla y coco tostado",
      "1 Cerveza artesanal o refresco"
    ],
    destacado: false
  },
  {
    categoria: "degustacion",
    nombre: 'Menú "Chef\'s Cyber Lab"',
    descripcion: "Para compartir en pareja. Fusión extrema con los sabores más rompedores de nuestra cocina.",
    precio: "54,00 € (2 pers.)",
    imagen: "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=500&h=350&fit=crop",
    tipo: "degustacion",
    incluye: [
      "2 Baos de panceta glaseada en salsa hoisin",
