type CategoriaId = "estrella" | "degustacion" | "grupos" | "llevar";

interface MenuItem {
  categoria: CategoriaId;
  nombre: string;
  descripcion: string;
  precio?: string;
  badge?: string;
  imagen?: string;
  tipo?: string;
  incluye?: string[];
  destacado?: boolean;
}

