    ],
    destacado: true
  },

  // ===== OFERTAS PARA LLEVAR =====
  {
    categoria: "llevar",
    nombre: 'Combo "Cyber-Night"',
    descripcion: "Domingos a Jueves. 2 burgers fusión + patatas + 2 bebidas con 20% de descuento exclusivo web.",
    precio: "22,90 €",
    imagen: "https://images.unsplash.com/photo-1550547660-d9450f859349?w=500&h=350&fit=crop",
    tipo: "takeaway",
    badge: "-20% WEB"
  },
  {
    categoria: "llevar",
    nombre: "The Solo Box",
    descripcion: "1 burger o sushi burrito + acompañante (aros de cebolla o patatas) + bebida. Precio cerrado imbatible.",
    precio: "13,50 €",
    imagen: "https://images.unsplash.com/photo-1561758033-d89a9ad46330?w=500&h=350&fit=crop",
    tipo: "takeaway"
  },
  {
    categoria: "llevar",
    nombre: 'Pack Oficinista "Fast & Premium"',
    descripcion: "Lunes a Viernes 12:00-16:00. Recoge en tienda en menos de 10 minutos. Plato principal + bebida + cold brew.",
    precio: "11,90 €",
    imagen: "https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=500&h=350&fit=crop",
