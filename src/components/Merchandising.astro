---
const products = [
  { id: 1, name: 'Camiseta de Hombre', category: 'textil', price: '24.99 €', desc: 'Negra con logo centrado en naranja y cian', image: '/img/CAMISETA%20CHICO.png' },
  { id: 2, name: 'Camiseta de Mujer (Holgada)', category: 'textil', price: '24.99 €', desc: 'Blanca con logo sutil en el pecho', image: '/img/CAMISETA%20CHICA.png' },
  { id: 3, name: 'Gorra Trucker', category: 'accesorios', price: '19.99 €', desc: 'Negra con frontal blanco y logo', image: '/img/GORRAS.png' },
  { id: 4, name: 'Toalla de Playa', category: 'playa', price: '29.99 €', desc: 'Negra con patrón de iconos street food', image: '/img/TOALLA%20PLAYA.png' },
  { id: 5, name: 'Nevera de Playa Rígida', category: 'playa', price: '49.99 €', desc: 'Blanca y negra con logotipo frontal', image: '/img/NEVERA%20BLANCA.png' },
  { id: 6, name: 'Botella Térmica (750ml)', category: 'hidratacion', price: '22.99 €', desc: 'Negra mate con logo vertical naranja', image: '/img/BOTELLA%20TERMICA.png' },
  { id: 7, name: 'Vaso Térmico de Café', category: 'hidratacion', price: '16.99 €', desc: 'Negro con logo en cian', image: '/img/VASO%20TERMICO.png' },
  { id: 8, name: 'Mochila Urbana Saco', category: 'accesorios', price: '34.99 €', desc: 'Lona negra con estampado naranja', image: '/img/MOCHILA.png' },
  { id: 9, name: 'Bolsa de Tela (Tote Bag)', category: 'textil', price: '12.99 €', desc: 'Algodón orgánico negro con diseño blanco', image: '/img/BOLSA%20TELA.png' },
  { id: 10, name: 'Delantal Profesional', category: 'hosteleria', price: '27.99 €', desc: 'Sarga negra con detalles en naranja', image: '/img/BOLSO.png' },
];
---

<section id="merch" class="menu-section">
  <div class="container">
    <div class="section-header">
      <p class="section-badge">COLECCIÓN VERANO 2026</p>
      <h2>THE WALKERS MERCH</h2>
      <p class="section-subtitle">
        Sabor callejero, técnica de autor llevada a tu estilo.
      </p>
    </div>

    <div class="menu-grid merch-grid" id="merchGrid">
      {products.map(p => (
        <article class="menu-card" data-categoria={p.category}>
          <div class="menu-card-image">
            <img src={p.image} alt={p.name} loading="lazy" />
            <span class="menu-badge">{p.category}</span>
          </div>
          <div class="menu-card-body">
            <h3 class="menu-card-title">{p.name}</h3>
            <p class="menu-card-desc">{p.desc}</p>
            <div class="menu-card-footer">
              <span class="menu-card-price">{p.price}</span>
              <button class="btn btn-cta">Añadir</button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .merch-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .merch-grid .menu-card {
    width: calc(25% - 1.125rem);
    min-width: 250px;
    max-width: 100%;
    box-sizing: border-box;
  }

  .merch-grid .menu-card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
    background-color: #1f1f1f;
  }

  .merch-grid .menu-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
    filter: brightness(0.85);
  }

  .merch-grid .menu-card:hover .menu-card-image img {
    transform: scale(1.05);
    filter: brightness(1);
  }

  .merch-grid .menu-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background-color: var(--color-accent);
    color: var(--color-white);
    font-family: var(--fuente-titulares);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.8rem;
    box-shadow: 0 0 15px rgba(255, 94, 54, 0.4);
  }

  .merch-grid .menu-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .merch-grid .menu-card-title {
    font-family: var(--fuente-titulares);
    font-size: 1.2rem;
    color: var(--color-blanco-puro);
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }

  .merch-grid .menu-card:hover .menu-card-title {
    color: var(--color-accent);
  }

  .merch-grid .menu-card-desc {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
    font-family: var(--fuente-cuerpo);
  }

  .merch-grid .menu-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: auto;
  }

  .merch-grid .menu-card-price {
    font-family: var(--fuente-titulares);
    font-size: 1.3rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  .merch-grid .btn-cta {
    font-family: var(--fuente-titulares);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    padding: 0.6rem 1.2rem;
    background-color: var(--color-accent);
    color: var(--color-white);
    border: none;
    cursor: pointer;
    transition: all 150ms ease;
    text-transform: uppercase;
    word-break: break-word;
    border-radius: 0.5rem;
  }

  .merch-grid .btn-cta:hover {
    background-color: var(--color-accent-hover);
    transform: scale(1.03);
  }

  .merch-grid .menu-card {
    background-color: var(--color-surface);
    border: 1px solid rgba(255, 94, 54, 0.1);
    border-radius: 0.75rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 300ms ease;
  }

  .merch-grid .menu-card:hover {
    transform: translateY(-6px);
    border-color: var(--color-accent);
    box-shadow: 0 0 25px rgba(255, 94, 54, 0.1);
  }

  @media (max-width: 768px) {
    .merch-grid .menu-card {
      width: 100%;
      min-width: 0;
    }
    .merch-grid .menu-card-image {
      height: 200px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .merch-grid .menu-card {
      width: calc(50% - 0.75rem);
    }
  }
</style>
