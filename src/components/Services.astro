---
import Card from './Card.astro';

const services = [
  {
    title: "ROLLS FUSIÓN",
    description: "Sushi reimaginado con ingredientes de autor. Rolls crujientes, bañados en salsas asiáticas con un toque mediterráneo que te sorprenderá.",
    image: "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=500&h=300&fit=crop",
    icon: "🥟"
  },
  {
    title: "TACOS ASIÁTICOS",
    description: "La fusión definitiva: tortilla de maíz con rellenos orientales. Short rib al miso, pollo tikka massala, tempura de langostino. Una explosión de sabor.",
    image: "https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=500&h=300&fit=crop",
    icon: "🌮"
  },
  {
    title: "BURGERS GOURMET",
    description: "Vacuno madurado, pan brioche artesano, salsas de autor. Smash burger con kimchi, teriyaki con foie, y nuestra icónica burger wasabi-mango.",
    image: "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=500&h=300&fit=crop",
    icon: "🍔"
  },
  {
    title: "BOWLS",
    description: "Poke bowls fusión con base de arroz sushi o quinoa. Salmón marinado, edamame, mango, aguacate y nuestra salsa especial walker. Frescura y potencia.",
    image: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=500&h=300&fit=crop",
    icon: "🥗"
  },
  {
    title: "BAOS",
    description: "Bollos al vapor esponjosos rellenos de cerdo caramelizado, pollo teriyaki o tempura de boniato. Coronados con encurtidos y salsa hoisin. El bocado perfecto.",
    image: "https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=500&h=300&fit=crop",
    icon: "🥟"
  }
];
---

<section id="servicios" class="services">
  <div class="container">
    <div class="section-header">
      <p class="section-badge">NUESTRA CARTA</p>
      <h2>FUSIÓN URBANA</h2>
      <p>Street food de autor con ingredientes selectos y técnica de vanguardia</p>
    </div>

    <div class="cards-grid">
      {services.map((service) => (
        <Card 
          title={service.title}
          description={service.description}
          image={service.image}
          icon={service.icon}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--spacing-sm);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 2.8rem;
  }

  .section-header p {
    font-size: 1.05rem;
    color: var(--color-muted);
    max-width: 550px;
    margin: 0 auto;
  }

  .cards-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-lg);
  }

  .cards-grid > :global(*) {
    flex: 0 1 280px;
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 2rem;
    }

    .cards-grid {
      gap: var(--spacing-md);
    }

    .cards-grid > :global(*) {
      flex: 0 1 100%;
    }
  }
</style>
