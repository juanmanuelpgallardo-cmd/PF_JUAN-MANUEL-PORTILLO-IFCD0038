---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'The Walkers | Street Food Fusión', description = 'Sabor callejero, técnica de autor. Rolls fusión, tacos asiáticos, burgers gourmet y bowls. The Walkers — fusión urbana con actitud.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    

  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingCTA />
  </body>
</html>

<style is:global>
  main {
    min-height: calc(100vh - 200px);
  }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    overflow-x: hidden;
  }

  ::selection {
    background-color: rgba(255, 94, 54, 0.3);
    color: var(--color-white);
  }
</style>
